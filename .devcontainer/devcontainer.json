{
  "name": "crypto-ai-trader",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
    "ghcr.io/devcontainers/features/go:1": { "version": "1.24" },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "forwardPorts": [5050, 5051, 5173],
  "portsAttributes": {
    "5050": { "label": "Flask Dashboard", "onAutoForward": "openPreview" },
    "5051": { "label": "Go Playground Server", "onAutoForward": "silent" },
    "5173": { "label": "Vite Dev Server", "onAutoForward": "openBrowser" }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1"
  },

  "remoteEnv": {
    "SUPABASE_URL": "${localEnv:SUPABASE_URL}",
    "SUPABASE_ANON_KEY": "${localEnv:SUPABASE_ANON_KEY}",
    "SUPABASE_SERVICE_ROLE_KEY": "${localEnv:SUPABASE_SERVICE_ROLE_KEY}",
    "SUPABASE_ACCESS_TOKEN": "${localEnv:SUPABASE_ACCESS_TOKEN}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "golang.go",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "denoland.vscode-deno",
        "supabase.supabase-vscode",
        "github.vscode-github-actions",
        "mkhl.direnv"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/venv/bin/python3",
        "python.terminal.activateEnvironment": false,
        "files.watcherExclude": {
          "**/venv/**": true,
          "**/node_modules/**": true,
          "**/simulations/data/**": true,
          "**/static/dist/**": true
        },
        "search.exclude": {
          "**/venv": true,
          "**/node_modules": true,
          "**/simulations/data": true
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "[python]": { "editor.defaultFormatter": "ms-python.black-formatter" },
        "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "deno.enablePaths": ["./supabase/functions"]
      }
    }
  },

  "remoteUser": "vscode"
}
